---
// src/components/MenuClient.astro
---

<div id="menu-container" class="w-full py-8">
  <p class="text-center text-text">Cargando productos...</p>
</div>

<script>
  interface Producto {
    id: number;
    name: string;
    description: string;
    price: number;
    categoryId: number;
    img: string;
  }

  // Los productos ya apuntan directamente a las 4 categorías consolidadas
  const CATEGORY_MAP: Record<number, string> = {
    26: "Entradas",
    27: "Platos Fuertes",
    28: "Bebidas",
    29: "Postres",
  };

  const CATEGORY_ORDER = ["Entradas", "Platos Fuertes", "Bebidas", "Postres"];

  interface ProductosPorCategoria {
    [key: string]: Producto[];
  }

  async function cargarProductos() {
    try {
      const response = await fetch(
        "https://wallpawawqisql-production.up.railway.app/productos"
      );

      if (!response.ok) {
        throw new Error(`Error: ${response.status}`);
      }

      const registros: Producto[] = await response.json();

      const productosPorCategoria: ProductosPorCategoria = {};

      registros.forEach((r) => {
        const categoria = CATEGORY_MAP[r.categoryId] ?? "Otros";
        if (!productosPorCategoria[categoria]) {
          productosPorCategoria[categoria] = [];
        }
        productosPorCategoria[categoria].push(r);
      });

      const categoriasConProductos = CATEGORY_ORDER.filter(
        (cat) => productosPorCategoria[cat]?.length > 0
      );

      const container = document.getElementById("menu-container");
      if (!container) {
        console.error("Menu container not found");
        return;
      }

      if (categoriasConProductos.length === 0) {
        container.innerHTML =
          '<p class="text-center text-text">No hay productos disponibles</p>';
        return;
      }

      container.innerHTML = categoriasConProductos
        .map(
          (categoria, index) => `
        <div class="mb-12">
          <h2 class="text-3xl font-bold mb-6 text-text px-4">${categoria}</h2>

          <div class="relative px-4">
            <div id="carousel-${index}" class="flex gap-4 overflow-x-auto scroll-smooth pb-4" style="scroll-behavior: smooth;">
              ${productosPorCategoria[categoria]
                .map(
                  (r) => `
                <div class="flex-shrink-0 w-80 bg-linear-to-br from-primary to-gost-hover rounded-xl shadow-lg overflow-hidden hover:shadow-2xl hover:scale-105 transition-all duration-300 relative group">
                  <div class="absolute top-3 right-3 bg-white/90 rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity z-10">
                    <button class="text-2xl hover:scale-110 transition-transform">🛒</button>
                  </div>
                  <img src="${r.img}" alt="${r.name}" class="w-full h-56 object-cover" />
                  <div class="p-5 bg-white/5 backdrop-blur">
                    <h3 class="text-lg font-bold mb-2 text-text line-clamp-2">${r.name}</h3>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-text-secondary">Precio</span>
                      <p class="text-xl font-bold text-text-feature">S/ ${r.price}</p>
                    </div>
                  </div>
                </div>
              `
                )
                .join("")}
            </div>

            <button
              class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-primary hover:bg-gost-hover text-white rounded-full p-3 shadow-lg transition-all duration-300 z-20"
              onclick="scrollCarousel('carousel-${index}', -400)"
              aria-label="Anterior"
            >
              ❮
            </button>
            <button
              class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-primary hover:bg-gost-hover text-white rounded-full p-3 shadow-lg transition-all duration-300 z-20"
              onclick="scrollCarousel('carousel-${index}', 400)"
              aria-label="Siguiente"
            >
              ❯
            </button>
          </div>
        </div>
      `
        )
        .join("");

      (window as any).scrollCarousel = (carouselId: string, offset: number) => {
        const carousel = document.getElementById(carouselId);
        if (carousel) {
          carousel.scrollBy({
            left: offset,
            behavior: "smooth",
          });
        }
      };
    } catch (error) {
      console.error("Error cargando productos:", error);
      const container = document.getElementById("menu-container");
      if (container) {
        container.innerHTML =
          '<p class="text-red-500 text-center">Error cargando productos</p>';
      }
    }
  }

  cargarProductos();
</script>

<style>
  #menu-container > div > div > div[id^="carousel-"] {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #menu-container > div > div > div[id^="carousel-"]::-webkit-scrollbar {
    display: none;
  }
</style>
