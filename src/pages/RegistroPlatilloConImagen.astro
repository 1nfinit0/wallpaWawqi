---
import Layout from "@layouts/Layout.astro";
import Logo from "@components/Logo.astro";
import Nav from "@components/Nav.astro";
import Ubicanos from "@components/Ubicanos.astro";
---

<Layout title="Registrar Platillo">
  <header class="w-full flex flex-col">
    <div
      class="w-full flex items-center justify-between bg-primary py-4 px-4 md:px-24"
    >
      <Logo />
      <Nav />
    </div>
  </header>

  <main
    class="w-full flex flex-col items-center justify-center py-12 px-4 md:px-24"
  >
    <form
      id="platilloForm"
      class="w-full max-w-md bg-white rounded-lg shadow-lg p-8 flex flex-col gap-6"
    >
      <h2 class="text-2xl font-bold text-gray-800 mb-2">Registrar Platillo</h2>

      <label class="block">
        <span class="text-gray-700 font-semibold mb-2 block">Nombre:</span>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </label>

      <label class="block">
        <span class="text-gray-700 font-semibold mb-2 block">Precio:</span>
        <input
          type="number"
          id="precio"
          name="precio"
          step="0.01"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </label>

      <label class="block">
        <span class="text-gray-700 font-semibold mb-2 block">Categoría:</span>
        <select
          id="categoria"
          name="categoria"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary bg-white"
        >
          <option value="" disabled selected>Selecciona una categoría</option>
          <option value="26">Entradas</option>
          <option value="27">Platos Fuertes</option>
          <option value="28">Bebidas</option>
          <option value="29">Postres</option>
        </select>
      </label>

      <label class="block">
        <span class="text-gray-700 font-semibold mb-2 block">Descripción:</span>
        <textarea
          id="descripcion"
          name="descripcion"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary resize-none h-28"
        ></textarea>
      </label>

      <label class="block">
        <span class="text-gray-700 font-semibold mb-2 block">Imagen:</span>
        <input
          type="file"
          id="imagen"
          name="imagen"
          accept="image/*"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <img id="preview" class="mt-3 max-w-full rounded-lg hidden" />
      </label>

      <button
        type="submit"
        class="w-full bg-text-feature hover:bg-text-secondary font-bold py-2 px-4 rounded-lg transition duration-200 text-primary"
      >
        Guardar
      </button>
    </form>

    <div id="resultado" class="mt-6 text-center text-sm"></div>
  </main>

  <footer>
    <Ubicanos />
  </footer>
</Layout>

<script>
  import { isLoggedIn } from "@libs/session";

  if (!isLoggedIn()) {
    window.location.href = `/login?redirect=${encodeURIComponent("/RegistroPlatilloConImagen")}`;
  }

  const form = document.getElementById("platilloForm") as HTMLFormElement | null;
  const imagenInput = document.getElementById("imagen") as HTMLInputElement | null;
  const categoriaSelect = document.getElementById("categoria") as HTMLSelectElement | null;
  const preview = document.getElementById("preview") as HTMLImageElement | null;
  const resultado = document.getElementById("resultado") as HTMLDivElement | null;

  if (form && imagenInput && categoriaSelect && preview && resultado) {
    imagenInput.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | null;
      const file = target?.files?.[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (ev) => {
          const result = ev.target?.result;
          if (typeof result === "string") {
            preview.src = result;
            preview.classList.remove("hidden");
          }
        };
        reader.readAsDataURL(file);
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      resultado.textContent = "";

      const file = imagenInput.files?.[0];
      if (!file) {
        resultado.textContent = "❌ Selecciona una imagen";
        resultado.className = "mt-6 text-center text-sm text-red-500";
        return;
      }

      const nombre = (document.getElementById("nombre") as HTMLInputElement).value;
      const descripcion = (document.getElementById("descripcion") as HTMLTextAreaElement).value;
      const precio = parseFloat((document.getElementById("precio") as HTMLInputElement).value);
      const categoryId = parseInt(categoriaSelect.value, 10);

      if (!categoryId) {
        resultado.textContent = "❌ Selecciona una categoría";
        resultado.className = "mt-6 text-center text-sm text-red-500";
        return;
      }

      const reader = new FileReader();
      reader.onload = async () => {
        const imagenBase64 = reader.result;

        const payload = {
          nombre,
          descripcion,
          precio,
          categoryId,
          imagenBase64,
        };

        try {
          const response = await fetch(
            "https://wallpawawqisql-production.up.railway.app/productos",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            }
          );

          if (response.ok) {
            const data = await response.json();
            resultado.textContent = `✅ Platillo creado! ID: ${data.id}`;
            resultado.className = "mt-6 text-center text-sm text-green-600";
            form.reset();
            preview.src = "";
            preview.classList.add("hidden");
          } else {
            const error = await response.json();
            resultado.textContent = `❌ Error: ${error.error}`;
            resultado.className = "mt-6 text-center text-sm text-red-500";
          }
        } catch (error) {
          const message = error instanceof Error ? error.message : "Error desconocido";
          resultado.textContent = `❌ Error de conexión: ${message}`;
          resultado.className = "mt-6 text-center text-sm text-red-500";
        }
      };
      reader.readAsDataURL(file);
    });
  }
</script>
