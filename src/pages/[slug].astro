---
interface Producto {
  id: string | number;
  name: string;
  description: string;
}

export async function getStaticPaths() {
  // Aquí obtienes todos los productos del backend
  const response = await fetch("https://wallpawawqisql-production.up.railway.app/productos");
  const productos: Producto[] = await response.json();

  // Generas las rutas
  return productos.map((producto: Producto) => ({
    params: { slug: producto.id.toString() },
    props: { producto },
  }));
}

const { producto } = Astro.props as { producto: Producto };
---

<h1>{producto.name}</h1>
<p>{producto.description}</p>
