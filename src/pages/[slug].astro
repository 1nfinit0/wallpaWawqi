---
interface Producto {
  id: string | number;
  name: string;
  description: string;
}

export const prerender = false;

const { slug } = Astro.params;

const response = await fetch(`https://wallpawawqisql-production.up.railway.app/productos/${slug}`);

if (response.status === 404) {
  return new Response("Producto no encontrado", { status: 404 });
}

if (!response.ok) {
  return new Response("Error al obtener producto", { status: 502 });
}

const producto: Producto = await response.json();
---
<h1>{producto.name}</h1>
<p>{producto.description}</p>
